# Ollama Modelfile for llm-jp-3-13b-instruct.
#
# Setup (one-time):
#   1) Download GGUF (example: Q4_K_M quant from mmnga):
#      curl -L -o /tmp/llm-jp-3-13b.Q4_K_M.gguf \
#        https://huggingface.co/mmnga/llm-jp-3-13b-instruct-gguf/resolve/main/llm-jp-3-13b-instruct-Q4_K_M.gguf
#   2) Update the FROM line below if your GGUF lives elsewhere.
#   3) Register with Ollama:
#      ollama create llm-jp-3 -f scripts/llm-jp-3.Modelfile
#   4) Verify:
#      ollama run llm-jp-3 "こんにちは"

FROM /tmp/llm-jp-3-13b.Q4_K_M.gguf

PARAMETER temperature 0.2
PARAMETER num_ctx 4096
PARAMETER stop "### 指示:"
PARAMETER stop "### 応答:"

TEMPLATE """{{ if .System }}{{ .System }}

{{ end }}### 指示:
{{ .Prompt }}

### 応答:
{{ .Response }}"""

SYSTEM """あなたは日本語で応答する AI アシスタントです。"""
